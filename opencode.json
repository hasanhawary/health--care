{
    "$schema": "https://opencode.ai/config.json",
    "skills": {
        "paths": [
            ".ai/skills"
        ]
    },
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "filesystem": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "."
            ]
        },
        "playwright": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ]
        },
        "context7": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        }
    }
}
